generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Mood {
  id        Int      @id @default(autoincrement())
  userId    String   // Clerk user ID (string)
  mood      String
  note      String?  // optional
  createdAt DateTime @default(now())
}